# ===== 必須（モック動作に必要）=====
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ===== モード =====
# MOCK_MODE=true にすると外部API呼び出しをすべてダミーデータで代替
MOCK_MODE=true

# ===== LINE（本番時に設定）=====
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ===== Google / GBP（本番時に設定）=====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== Supabase（本番時に設定）=====
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
